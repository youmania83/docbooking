# AiSensy WhatsApp OTP System - Environment Variables

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?appName=DocBooking

# Admin Authentication
ADMIN_PASSWORD=your_admin_password

# Email Configuration (Optional - for notifications)
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# WATI WhatsApp Integration (Alternative to AiSensy)
WATI_API_TOKEN=your_wati_api_token
WATI_BASE_URL=https://live-server.wati.io

# ============================================================
# AiSensy WhatsApp API Configuration (ACTIVE)
# ============================================================

# Get your credentials from: https://www.aisensy.com
# 1. Login to AiSensy Dashboard
# 2. Go to Settings → API
# 3. Copy your API Key

# Your API Key from AiSensy dashboard
AISENSY_API_KEY=your_actual_api_key_here

# Campaign Name (must match your template in AiSensy)
# Default: docbooking_otp
AISENSY_CAMPAIGN_NAME=docbooking_otp

# AiSensy API Endpoint
# Default: https://api.aisensy.com/send-message
AISENSY_API_URL=https://api.aisensy.com/send-message

# ============================================================
# Node Environment
# ============================================================
NODE_ENV=development
# NODE_ENV=production (for Vercel)
